Package: admixr2
Type: Package
Title: Aggregate Data Modelling
Version: 0.1.0
Authors@R: c(
        person("H.", "van de Beek", email = "h.van.de.beek@lacdr.leidenuniv.nl", role = c("aut", "cre")),
        person("P.A.J.", "Välitalo", role = "aut"),
        person("L.B.", "Zwep", role = "aut"),
        person("J.G.C.", "van Hasselt", role = "aut")
